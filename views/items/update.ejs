<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head.ejs') %>
  <body>
    <div class="container">
      <%- include('../partials/headline.ejs') %> <%-
      include('../partials/header.ejs') %>
      <form action="/items/update/<%= item.id%>" method="post">
        <label for="name" data-field>
          Name
          <input
            placeholder="Enter a name for the item"
            type="text"
            name="name"
            value=<%= item.name %>
            required
          />
        </label>
        <label for="price" data-field>
          Price
          <input
            placeholder="Enter a price for the item"
            type="number"
            name="price"
            value=<%= item.price %>
            required
          />
        </label>
        <div data-field>
          <label for="category_id">Category</label>
          <select name="category_id" required>
            <option disabled value="">Select a category</option>
            <% categories.forEach(category => { %>
             <option <%= category.id === item.category_id ? "selected" : "" %> value=<%= category.id %> ><%= category.name %></option>
            <% }) %>
          </select>
        </div>

        <button type="submit">Update</button>
      </form>
    </div>
  </body>
</html>
